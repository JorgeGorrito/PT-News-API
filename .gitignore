# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work

# Build output
bin/
dist/
build/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log

# Temporary files
tmp/
temp/

# Docker volumes (local data)
mysql_data/

# Generated Swagger documentation (auto-generated on build)
docs/docs.go
docs/swagger.json
docs/swagger.yaml

# OS specific
Thumbs.db
